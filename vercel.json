{
  "functions": {
    "api/proxy.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/hobom-internal/api/v1/(.*)",
      "destination": "/api/proxy?path=/hobom-internal/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
